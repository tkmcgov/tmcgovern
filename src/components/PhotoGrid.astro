---
import { Picture, getImage } from 'astro:assets';
import type { Photo, Video } from '../lib/albums';

/*
 * Masonry grid of photos (and optionally self-hosted videos), ordered
 * together by filename in ROW order — items read left-to-right, top to
 * bottom. Photos open in the shared Lightbox — include <Lightbox /> once
 * on any page that uses this component.
 */
interface Props {
  photos: Photo[];
  videos?: Video[];
  /** used for alt text on photos without a caption */
  contextTitle: string;
  /** 'rows' → justified rows in strict story order; default masonry */
  layout?: string;
}

const { photos, videos = [], contextTitle, layout } = Astro.props;

/* pre-render a large optimized version of each photo for the lightbox */
const fullSize = new Map(
  await Promise.all(
    photos.map(async (photo) => {
      const large = await getImage({ src: photo.image, width: 2400, format: 'webp', quality: 80 });
      return [photo.file, large.src] as const;
    }),
  ),
);

type MediaItem = { kind: 'photo'; item: Photo; index: number } | { kind: 'video'; item: Video };

const media: MediaItem[] = [
  ...photos.map((item, index) => ({ kind: 'photo', item, index }) as const),
  ...videos.map((item) => ({ kind: 'video', item }) as const),
].sort((a, b) => a.item.file.localeCompare(b.item.file));
---

<div class="mt-12" data-photo-grid data-layout={layout === 'rows' ? 'rows' : 'masonry'}>
  {
    media.map((entry) =>
      entry.kind === 'photo' ? (
        <a
          href={fullSize.get(entry.item.file)}
          class="lightbox-link grid-item group mb-5 block"
          data-index={entry.index}
          data-caption={entry.item.caption ?? ''}
        >
          <Picture
            src={entry.item.image}
            alt={entry.item.caption ?? `${contextTitle} — photograph ${entry.index + 1}`}
            widths={[480, 800, 1200]}
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            formats={['avif', 'webp']}
            fallbackFormat="webp"
            class="w-full transition-opacity duration-300 group-hover:opacity-85"
          />
          {entry.item.caption && (
            <p class="mt-2 text-xs leading-relaxed text-fog">{entry.item.caption}</p>
          )}
        </a>
      ) : (
        <div class="grid-item mb-5">
          <video
            controls
            playsinline
            preload="metadata"
            loop={entry.item.loop}
            class="w-full"
            src={entry.item.url}
          />
          {entry.item.caption && (
            <p class="mt-2 text-xs leading-relaxed text-fog">{entry.item.caption}</p>
          )}
        </div>
      ),
    )
  }
</div>

<script>
  /*
   * Masonry that preserves story order: items are placed one at a time,
   * in filename order, each into whichever column is currently shortest.
   * Columns stay visually balanced and the sequence flows down the page.
   * Re-lays out when the responsive column count changes and when video
   * dimensions become known.
   */
  const breakpoints: Array<[MediaQueryList, number]> = [
    [window.matchMedia('(min-width: 1024px)'), 3],
    [window.matchMedia('(min-width: 640px)'), 2],
  ];

  function columnCount(): number {
    for (const [query, count] of breakpoints) if (query.matches) return count;
    return 1;
  }

  /* width ÷ height of the media inside a grid item */
  function aspectOf(item: HTMLElement): number {
    const img = item.querySelector('img');
    if (img) {
      const w = Number(img.getAttribute('width'));
      const h = Number(img.getAttribute('height'));
      if (w > 0 && h > 0) return w / h;
    }
    const video = item.querySelector('video');
    if (video && video.videoWidth > 0) return video.videoWidth / video.videoHeight;
    return 16 / 9;
  }

  for (const grid of document.querySelectorAll<HTMLElement>('[data-photo-grid]')) {
    const items = [...grid.querySelectorAll<HTMLElement>('.grid-item')];
    const mode = grid.dataset.layout;

    /* masonry: each item, in order, into the currently shortest column */
    const masonryLayout = () => {
      const columns = columnCount();
      grid.textContent = '';
      grid.classList.add('flex', 'items-start', 'gap-5');
      const wrappers = Array.from({ length: columns }, () => {
        const wrapper = document.createElement('div');
        wrapper.className = 'min-w-0 flex-1';
        grid.appendChild(wrapper);
        return wrapper;
      });
      const heights = new Array(columns).fill(0);
      for (const item of items) {
        const shortest = heights.indexOf(Math.min(...heights));
        wrappers[shortest]!.appendChild(item);
        heights[shortest] += item.offsetHeight;
      }
    };

    /* justified rows: strict story order; every item in a row shares a
       height, widths follow each item's aspect ratio, rows fill the width */
    const rowsLayout = () => {
      const width = grid.clientWidth;
      const gap = 20; /* matches gap-5 */
      grid.textContent = '';
      grid.classList.remove('items-start');
      grid.classList.add('flex', 'flex-col', 'gap-5');
      for (const item of items) item.classList.remove('mb-5');

      if (width < 640) {
        for (const item of items) {
          item.style.width = '100%';
          grid.appendChild(item);
        }
        return;
      }

      const target = 340; /* preferred row height in px */
      let row: Array<{ item: HTMLElement; aspect: number }> = [];
      let rowAspect = 0;

      const flushRow = (isLast: boolean) => {
        if (row.length === 0) return;
        const usable = width - gap * (row.length - 1) - 1;
        let height = usable / rowAspect;
        if (isLast && height > target * 1.2) height = target;
        const rowDiv = document.createElement('div');
        rowDiv.className = 'flex items-start gap-5';
        for (const { item, aspect } of row) {
          item.style.width = `${aspect * height}px`;
          item.style.flex = '0 0 auto';
          item.style.maxWidth = '100%';
          rowDiv.appendChild(item);
        }
        grid.appendChild(rowDiv);
        row = [];
        rowAspect = 0;
      };

      for (const item of items) {
        const aspect = aspectOf(item);
        row.push({ item, aspect });
        rowAspect += aspect;
        if (rowAspect * target + gap * (row.length - 1) >= width) flushRow(false);
      }
      flushRow(true);
    };

    const layout = mode === 'rows' ? rowsLayout : masonryLayout;

    layout();
    if (mode === 'rows') {
      /* row widths are pixel-based — recompute on any resize */
      let resizePending: ReturnType<typeof setTimeout> | undefined;
      window.addEventListener('resize', () => {
        clearTimeout(resizePending);
        resizePending = setTimeout(layout, 150);
      });
    } else {
      for (const [query] of breakpoints) query.addEventListener('change', () => layout());
    }

    /* video dimensions are unknown until their metadata loads — re-run once known */
    let pending: ReturnType<typeof setTimeout> | undefined;
    for (const video of grid.querySelectorAll('video')) {
      video.addEventListener('loadedmetadata', () => {
        clearTimeout(pending);
        pending = setTimeout(layout, 150);
      });
    }
  }
</script>
