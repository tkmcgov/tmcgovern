---
import { Picture, getImage } from 'astro:assets';
import type { Photo } from '../lib/albums';

/*
 * Masonry photo grid whose photos open in the shared Lightbox —
 * include <Lightbox /> once on any page that uses this component.
 */
interface Props {
  photos: Photo[];
  /** used for alt text on photos without a caption */
  contextTitle: string;
}

const { photos, contextTitle } = Astro.props;

/* pre-render a large optimized version of each photo for the lightbox */
const fullSize = await Promise.all(
  photos.map((photo) =>
    getImage({ src: photo.image, width: 2400, format: 'webp', quality: 80 }),
  ),
);
---

<div class="mt-12 columns-1 gap-5 sm:columns-2 lg:columns-3 [&>*]:mb-5">
  {
    photos.map((photo, i) => (
      <a
        href={fullSize[i]!.src}
        class="lightbox-link group block break-inside-avoid"
        data-caption={photo.caption ?? ''}
      >
        <Picture
          src={photo.image}
          alt={photo.caption ?? `${contextTitle} — photograph ${i + 1}`}
          widths={[480, 800, 1200]}
          sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
          formats={['avif', 'webp']}
          fallbackFormat="webp"
          class="w-full transition-opacity duration-300 group-hover:opacity-85"
        />
        {photo.caption && (
          <p class="mt-2 text-xs leading-relaxed text-fog">{photo.caption}</p>
        )}
      </a>
    ))
  }
</div>
