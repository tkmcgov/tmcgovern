---
/*
 * Full-screen photo viewer. Include ONCE per page, after any PhotoGrid(s).
 * It picks up every .lightbox-link on the page, so multiple grids share
 * one viewer.
 */
---

<dialog id="lightbox" aria-label="Photo viewer">
  <div class="flex h-full w-full flex-col items-center justify-center">
    <img id="lightbox-img" src="" alt="" class="max-h-[85svh] max-w-[96vw] object-contain" />
    <p id="lightbox-caption" class="mt-3 px-6 text-center text-xs text-fog"></p>
  </div>
  <button
    id="lightbox-close"
    aria-label="Close"
    class="absolute right-4 top-4 p-3 text-2xl leading-none text-fog hover:text-snow"
  >
    ✕
  </button>
  <button
    id="lightbox-prev"
    aria-label="Previous photo"
    class="absolute left-2 top-1/2 -translate-y-1/2 p-4 text-3xl text-fog hover:text-snow"
  >
    ‹
  </button>
  <button
    id="lightbox-next"
    aria-label="Next photo"
    class="absolute right-2 top-1/2 -translate-y-1/2 p-4 text-3xl text-fog hover:text-snow"
  >
    ›
  </button>
</dialog>

<script>
  const links = [...document.querySelectorAll<HTMLAnchorElement>('.lightbox-link')];
  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const img = document.getElementById('lightbox-img') as HTMLImageElement;
  const caption = document.getElementById('lightbox-caption')!;
  let current = 0;
  let savedScrollY = 0;

  /* freeze the page behind the viewer (reliable on iOS, unlike overflow:hidden) */
  function lockScroll() {
    savedScrollY = window.scrollY;
    document.body.style.position = 'fixed';
    document.body.style.top = `-${savedScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
  }

  function unlockScroll() {
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    window.scrollTo(0, savedScrollY);
  }

  function show(index: number) {
    current = (index + links.length) % links.length;
    const link = links[current]!;
    img.src = link.href;
    img.alt = link.dataset.caption || 'Photograph';
    caption.textContent = link.dataset.caption || '';
  }

  links.forEach((link, i) => {
    link.addEventListener('click', (event) => {
      event.preventDefault();
      show(i);
      lockScroll();
      dialog.showModal();
    });
  });

  dialog.addEventListener('close', unlockScroll);

  document.getElementById('lightbox-close')!.addEventListener('click', () => dialog.close());
  document.getElementById('lightbox-prev')!.addEventListener('click', () => show(current - 1));
  document.getElementById('lightbox-next')!.addEventListener('click', () => show(current + 1));

  dialog.addEventListener('click', (event) => {
    if (event.target === dialog) dialog.close();
  });

  document.addEventListener('keydown', (event) => {
    if (!dialog.open) return;
    if (event.key === 'ArrowLeft') show(current - 1);
    if (event.key === 'ArrowRight') show(current + 1);
  });
</script>
