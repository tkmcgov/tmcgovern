---
import Base from '../layouts/Base.astro';

export const prerender = true;

const completed = [
  {
    name: 'Catskill 3500 Club',
    date: 'August 20, 2015',
    member: '#2455',
    description:
      'Every Catskill peak above 3,500 feet — 35 summits, four of them climbed a second time in winter, as the club requires.',
  },
  {
    name: 'Catskill 3500 — Winter',
    date: 'March 20, 2024',
    member: '#1666',
    description: 'The full Catskill list again, this time entirely in calendar winter.',
  },
  {
    name: 'Adirondack 46ers',
    date: 'June 17, 2015',
    member: '#8919',
    description: 'All 46 High Peaks of the Adirondacks.',
  },
  {
    name: 'New Hampshire 48',
    date: 'August 31, 2022',
    member: null,
    description: "New Hampshire's 48 four-thousand-footers, deep in the White Mountains.",
  },
  {
    name: 'New England 4,000-Footers',
    date: 'September 24, 2024',
    member: null,
    description: 'All 67 four-thousand-footers across New Hampshire, Vermont, and Maine.',
  },
  {
    name: 'Northeast 111',
    date: 'September 24, 2024',
    member: '#1331',
    description:
      'Every four-thousand-footer in the Northeast — New England plus New York, 115 summits on the modern list.',
  },
  {
    name: 'Northville–Placid Trail',
    date: 'July 14, 2020',
    member: null,
    description: 'Through-hike of the 138-mile trail across the Adirondack wilderness, Northville to Lake Placid.',
  },
  {
    name: 'Taconic Crest Trail',
    date: 'August 27, 2023',
    member: null,
    description: '37 miles along the ridge of the New York–Massachusetts–Vermont border — in a single day.',
  },
  {
    name: 'The Long Trail',
    date: 'September 10, 2024',
    member: null,
    description:
      "End-to-end through-hike of America's oldest long-distance trail: 272 miles along the spine of Vermont.",
  },
];

const inProgress = [
  {
    name: '50 State Highpoints',
    done: 27,
    total: 50,
    description: 'The highest point of every U.S. state.',
  },
  {
    name: 'Colorado 14ers',
    done: 10,
    total: 58,
    description: "Colorado's peaks above 14,000 feet.",
  },
];
---

<Base
  title="Hikes — Terrance McGovern"
  description="Peak lists, through-hikes, and long days on foot — the completed challenges and the ones still in progress."
>
  <div class="mx-auto max-w-4xl px-5 pb-20 pt-28 sm:px-8 sm:pt-32">
    <h1 class="text-3xl font-light sm:text-4xl">Hikes</h1>
    <p class="mt-4 max-w-2xl text-sm leading-relaxed text-fog sm:text-base">
      I like a challenge — ideally one measured in summits, miles, or both. Give me a list and
      I'll want to finish it. A lot of these started in college: I went to RPI in Troy, New York,
      which put the Catskills, the Adirondacks, and the Taconics within weekend range, and the
      habit never wore off.
    </p>

    <section class="mt-14">
      <h2 class="mb-2 text-xs uppercase tracking-[0.35em] text-fog">Completed</h2>
      <ul class="divide-y divide-line border-y border-line">
        {
          completed.map((item) => (
            <li class="grid gap-1 py-5 sm:grid-cols-[1fr_auto] sm:gap-6">
              <div>
                <h3 class="text-sm uppercase tracking-[0.2em] text-snow">{item.name}</h3>
                <p class="mt-1 text-sm leading-relaxed text-fog">{item.description}</p>
              </div>
              <div class="text-xs text-fog sm:text-right">
                <p class="whitespace-nowrap">{item.date}</p>
                {item.member && <p class="mt-1 whitespace-nowrap">Member {item.member}</p>}
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14">
      <h2 class="mb-2 text-xs uppercase tracking-[0.35em] text-fog">In progress</h2>
      <ul class="divide-y divide-line border-y border-line">
        {
          inProgress.map((item) => (
            <li class="py-5">
              <div class="flex items-baseline justify-between gap-6">
                <h3 class="text-sm uppercase tracking-[0.2em] text-snow">{item.name}</h3>
                <p class="whitespace-nowrap text-xs text-fog">
                  {item.done} of {item.total}
                </p>
              </div>
              <p class="mt-1 text-sm leading-relaxed text-fog">{item.description}</p>
              <div class="mt-3 h-1 w-full bg-line">
                <div class="h-1 bg-snow/70" style={`width: ${Math.round((item.done / item.total) * 100)}%`} />
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    <a href="/hikes/country-high-points/" class="group mt-14 block border border-line p-6 transition-colors hover:border-fog sm:p-8">
      <p class="text-xs uppercase tracking-[0.35em] text-fog">The long game</p>
      <h2 class="mt-2 text-xl font-light text-snow sm:text-2xl">Country High Points</h2>
      <p class="mt-2 max-w-xl text-sm leading-relaxed text-fog">
        The highest point of entire countries — thirteen so far, from volcano rims to a hill in
        Singapore.
      </p>
      <p class="mt-3 text-xs uppercase tracking-[0.25em] text-fog transition-colors group-hover:text-snow">
        See the list →
      </p>
    </a>
  </div>
</Base>
