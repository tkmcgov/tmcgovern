---
import { Picture } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { getAlbums } from '../../lib/albums';

export const prerender = true;

const albums = getAlbums();
const featured = albums.filter((a) => a.featured);
const rest = albums.filter((a) => !a.featured);
---

<Base
  title="Galleries — Terrance McGovern"
  description="Photo galleries from hikes around the world and astrophotography from Antarctica."
>
  <div class="mx-auto max-w-6xl px-5 pb-20 pt-28 sm:px-8 sm:pt-32">
    <h1 class="text-3xl font-light sm:text-4xl">Galleries</h1>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-fog">
      Albums from trips on foot — and long nights under the southern sky.
    </p>

    {
      featured.length > 0 && (
        <section class="mt-14">
          <h2 class="mb-6 text-xs uppercase tracking-[0.35em] text-fog">Featured</h2>
          {featured.map((album) => (
            <a href={`/galleries/${album.slug}/`} class="group relative mb-8 block overflow-hidden">
              <Picture
                src={album.cover}
                alt={album.title}
                widths={[640, 1024, 1600, 2400]}
                sizes="(min-width: 1152px) 1088px, 100vw"
                formats={['avif', 'webp']}
                fallbackFormat="webp"
                class:list={[
                  'w-full transition-transform duration-700 group-hover:scale-[1.03]',
                  album.cover.width <= album.cover.height && 'aspect-[21/9] object-cover',
                ]}
              />
              <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-night/90 via-transparent to-transparent p-6 sm:p-10">
                <h3 class="text-2xl font-light sm:text-3xl">{album.title}</h3>
                {album.description && (
                  <p class="mt-2 hidden max-w-xl text-sm text-fog sm:block">{album.description}</p>
                )}
                <p class="mt-3 text-xs uppercase tracking-[0.25em] text-fog">
                  {album.photos.length} photographs →
                </p>
              </div>
            </a>
          ))}
        </section>
      )
    }

    <section class="mt-14">
      <h2 class="mb-6 text-xs uppercase tracking-[0.35em] text-fog">All journeys</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          rest.map((album) => (
            <a href={`/galleries/${album.slug}/`} class="group block">
              <div class="overflow-hidden">
                <Picture
                  src={album.cover}
                  alt={album.title}
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                  formats={['avif', 'webp']}
                  fallbackFormat="webp"
                  class:list={[
                    'w-full transition-transform duration-500 group-hover:scale-105',
                    album.cover.width <= album.cover.height && 'aspect-[4/3] object-cover',
                  ]}
                />
              </div>
              <h3 class="mt-4 text-sm uppercase tracking-[0.2em]">{album.title}</h3>
              {album.description && (
                <p class="mt-1 line-clamp-2 text-xs leading-relaxed text-fog">{album.description}</p>
              )}
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>
