---
import { Picture, getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { getAlbums } from '../../lib/albums';

export const prerender = true;

export function getStaticPaths() {
  return getAlbums().map((album) => ({
    params: { album: album.slug },
    props: { album },
  }));
}

const { album } = Astro.props;

/* pre-render a large optimized version of each photo for the lightbox */
const fullSize = await Promise.all(
  album.photos.map((photo) =>
    getImage({ src: photo.image, width: 2400, format: 'webp', quality: 80 }),
  ),
);
---

<Base
  title={`${album.title} — Terrance McGovern`}
  description={album.description ?? `Photographs from ${album.title} by Terrance McGovern.`}
>
  <div class="mx-auto max-w-6xl px-5 pb-20 pt-28 sm:px-8 sm:pt-32">
    <nav class="mb-6 text-xs uppercase tracking-[0.25em] text-fog">
      <a href="/galleries/" class="transition-colors hover:text-snow">Galleries</a>
      <span class="mx-2">/</span>
      <span class="text-snow">{album.title}</span>
    </nav>
    <h1 class="text-3xl font-light sm:text-4xl">{album.title}</h1>
    {
      album.description && (
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-fog">{album.description}</p>
      )
    }

    <div class="mt-12 columns-1 gap-5 sm:columns-2 lg:columns-3 [&>*]:mb-5">
      {
        album.photos.map((photo, i) => (
          <a
            href={fullSize[i]!.src}
            class="lightbox-link group block break-inside-avoid"
            data-index={i}
            data-caption={photo.caption ?? ''}
          >
            <Picture
              src={photo.image}
              alt={photo.caption ?? `${album.title} — photograph ${i + 1}`}
              widths={[480, 800, 1200]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              formats={['avif', 'webp']}
              fallbackFormat="webp"
              class="w-full transition-opacity duration-300 group-hover:opacity-85"
            />
            {photo.caption && (
              <p class="mt-2 text-xs leading-relaxed text-fog">{photo.caption}</p>
            )}
          </a>
        ))
      }
    </div>

    <p class="mt-14 border-t border-line pt-8 text-sm text-fog">
      Interested in one of these as a print?
      <a href="/prints/" class="text-snow underline decoration-fog/50 underline-offset-4 hover:decoration-snow">
        Get in touch.
      </a>
    </p>
  </div>

  <dialog id="lightbox" aria-label="Photo viewer">
    <div class="flex h-full w-full flex-col items-center justify-center">
      <img id="lightbox-img" src="" alt="" class="max-h-[88svh] max-w-[96vw] object-contain" />
      <p id="lightbox-caption" class="mt-3 px-6 text-center text-xs text-fog"></p>
    </div>
    <button
      id="lightbox-close"
      aria-label="Close"
      class="absolute right-4 top-4 p-3 text-2xl leading-none text-fog hover:text-snow"
    >
      ✕
    </button>
    <button
      id="lightbox-prev"
      aria-label="Previous photo"
      class="absolute left-2 top-1/2 -translate-y-1/2 p-4 text-3xl text-fog hover:text-snow"
    >
      ‹
    </button>
    <button
      id="lightbox-next"
      aria-label="Next photo"
      class="absolute right-2 top-1/2 -translate-y-1/2 p-4 text-3xl text-fog hover:text-snow"
    >
      ›
    </button>
  </dialog>

  <script>
    const links = [...document.querySelectorAll<HTMLAnchorElement>('.lightbox-link')];
    const dialog = document.getElementById('lightbox') as HTMLDialogElement;
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const caption = document.getElementById('lightbox-caption')!;
    let current = 0;

    function show(index: number) {
      current = (index + links.length) % links.length;
      const link = links[current]!;
      img.src = link.href;
      img.alt = link.dataset.caption || 'Photograph';
      caption.textContent = link.dataset.caption || '';
    }

    links.forEach((link, i) => {
      link.addEventListener('click', (event) => {
        event.preventDefault();
        show(i);
        dialog.showModal();
      });
    });

    document.getElementById('lightbox-close')!.addEventListener('click', () => dialog.close());
    document.getElementById('lightbox-prev')!.addEventListener('click', () => show(current - 1));
    document.getElementById('lightbox-next')!.addEventListener('click', () => show(current + 1));

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });

    document.addEventListener('keydown', (event) => {
      if (!dialog.open) return;
      if (event.key === 'ArrowLeft') show(current - 1);
      if (event.key === 'ArrowRight') show(current + 1);
    });
  </script>
</Base>
