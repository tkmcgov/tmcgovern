---
import Base from '../../layouts/Base.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getAlbums } from '../../lib/albums';

export const prerender = true;

export function getStaticPaths() {
  return getAlbums().map((album) => ({
    params: { album: album.slug },
    props: { album },
  }));
}

const { album } = Astro.props;
---

<Base
  title={`${album.title} — Terrance McGovern`}
  description={album.description ?? `Photographs from ${album.title} by Terrance McGovern.`}
>
  <div class="mx-auto max-w-6xl px-5 pb-20 pt-28 sm:px-8 sm:pt-32">
    <nav class="mb-6 text-xs uppercase tracking-[0.25em] text-fog">
      <a href="/galleries/" class="transition-colors hover:text-snow">Galleries</a>
      <span class="mx-2">/</span>
      <span class="text-snow">{album.title}</span>
    </nav>
    <h1 class="text-3xl font-light sm:text-4xl">{album.title}</h1>
    {
      album.description && (
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-fog">{album.description}</p>
      )
    }

    <PhotoGrid photos={album.photos} contextTitle={album.title} />
    <Lightbox />

    <p class="mt-14 border-t border-line pt-8 text-sm text-fog">
      Interested in one of these as a print?
      <a href="/prints/" class="text-snow underline decoration-fog/50 underline-offset-4 hover:decoration-snow">
        Get in touch.
      </a>
    </p>
  </div>
</Base>
