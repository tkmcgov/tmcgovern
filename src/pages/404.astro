---
import Base from '../layouts/Base.astro';

export const prerender = true;
---

<Base title="Page not found — Terrance McGovern">
  <div class="mx-auto flex min-h-svh max-w-2xl flex-col items-start justify-center px-5 sm:px-8">
    <p class="text-xs uppercase tracking-[0.35em] text-fog">404</p>
    <h1 class="mt-3 text-3xl font-light sm:text-4xl">This trail doesn't exist.</h1>
    <a
      href="/"
      class="mt-8 border border-snow/80 px-6 py-3 text-xs uppercase tracking-[0.25em] text-snow transition-colors hover:bg-snow hover:text-night"
    >
      Back to camp
    </a>
  </div>
</Base>
