---
import Base from '../../layouts/Base.astro';

export const prerender = true;

const countries = [
  { country: 'Guatemala', peak: 'Volcán Tajumulco' },
  { country: 'Costa Rica', peak: 'Cerro Chirripó' },
  { country: 'Panama', peak: 'Volcán Barú' },
  { country: 'Ireland', peak: 'Carrauntoohil' },
  { country: 'Romania', peak: 'Moldoveanu' },
  { country: 'Bulgaria', peak: 'Musala' },
  { country: 'San Marino', peak: 'Monte Titano' },
  { country: 'Monaco', peak: 'Chemin des Révoires' },
  { country: 'Malta', peak: 'Ta’ Dmejrek' },
  { country: 'Wales', peak: 'Yr Wyddfa (Snowdon)' },
  { country: 'Jamaica', peak: 'Blue Mountain Peak' },
  { country: 'Singapore', peak: 'Bukit Timah Hill' },
  { country: 'Portugal', peak: 'Ponta do Pico' },
];
---

<Base
  title="Country High Points — Terrance McGovern"
  description="Standing on the highest point of entire countries — thirteen so far, from volcano rims to a hill in Singapore."
>
  <div class="mx-auto max-w-4xl px-5 pb-20 pt-28 sm:px-8 sm:pt-32">
    <nav class="mb-6 text-xs uppercase tracking-[0.25em] text-fog">
      <a href="/hikes/" class="transition-colors hover:text-snow">Hikes</a>
      <span class="mx-2">/</span>
      <span class="text-snow">Country High Points</span>
    </nav>

    <h1 class="text-3xl font-light sm:text-4xl">Country High Points</h1>
    <div class="mt-4 max-w-2xl space-y-4 text-sm leading-relaxed text-fog sm:text-base">
      <p>
        The purest version of the game: stand on the highest point of an entire country. Some are
        serious mountains, some are volcano rims, and one is a very pleasant hill in Singapore —
        but each one puts you, briefly, above everyone else in the nation.
      </p>
      <p>
        There are nearly two hundred countries, so I don't expect to ever finish this list — but
        it would be amazing to be able to dedicate the time to it. Someone actually is trying to
        climb them all:
        <a
          href="https://www.countryhighpoints.com/"
          class="text-snow underline decoration-fog/50 underline-offset-4 hover:decoration-snow"
        >countryhighpoints.com</a>
        — you should check them out.
      </p>
    </div>

    <section class="mt-14">
      <h2 class="mb-2 text-xs uppercase tracking-[0.35em] text-fog">
        Climbed so far — {countries.length}
      </h2>
      <ul class="divide-y divide-line border-y border-line sm:columns-1">
        {
          countries.map((item) => (
            <li class="flex items-baseline justify-between gap-6 py-4">
              <span class="text-sm uppercase tracking-[0.2em] text-snow">{item.country}</span>
              <span class="text-right text-sm text-fog">{item.peak}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <p class="mt-14 text-sm text-fog">
      <a href="/hikes/" class="text-snow underline decoration-fog/50 underline-offset-4 hover:decoration-snow">
        ← Back to Hikes
      </a>
    </p>
  </div>
</Base>
