---
import Base from '../layouts/Base.astro';

export const prerender = true;
---

<Base
  title="Gear — Terrance McGovern"
  description="Field-tested gear notes from Antarctica and the trail — coming soon."
>
  <div class="mx-auto flex min-h-svh max-w-2xl flex-col items-start justify-center px-5 sm:px-8">
    <p class="text-xs uppercase tracking-[0.35em] text-fog">Coming soon</p>
    <h1 class="mt-3 text-3xl font-light sm:text-4xl">Gear</h1>
    <p class="mt-4 text-sm leading-relaxed text-fog sm:text-base">
      A straight-talking rundown of what I actually carry and stand by — tested on the trail, in
      the water, and through the Antarctic winter. No sponsorships, no filler. Notes from the
      field are being written between shifts.
    </p>
    <a
      href="/galleries/"
      class="mt-8 border border-snow/80 px-6 py-3 text-xs uppercase tracking-[0.25em] text-snow transition-colors hover:bg-snow hover:text-night"
    >
      Meanwhile, the galleries
    </a>
  </div>
</Base>
