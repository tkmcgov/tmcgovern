{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tmcgovern-portfolio",
  "compatibility_date": "2026-07-16",
  "main": "dist/_worker.js/index.js",
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"]
}
